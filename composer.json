{
    "name": "brdd/brdd-php",
    "description": "Business Rule Driven Design (BRDD) core interfaces and contexts for PHP.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Brdd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brdd\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
